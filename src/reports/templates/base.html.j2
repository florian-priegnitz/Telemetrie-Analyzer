<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<title>{% block title %}Telemetrie Analyzer Report{% endblock %}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
         color: #1f2328; max-width: 1100px; margin: 2rem auto; padding: 0 1.5rem;
         background: #fafbfc; line-height: 1.5; }
  h1, h2, h3 { color: #24292f; margin-top: 1.8em; }
  h1 { border-bottom: 2px solid #d0d7de; padding-bottom: .4rem; }
  table { border-collapse: collapse; width: 100%; margin: 1rem 0; background: white; }
  th, td { padding: .5rem .8rem; border: 1px solid #d0d7de; text-align: left; vertical-align: top; }
  th { background: #f6f8fa; font-weight: 600; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 0.85em;
           font-weight: 600; color: white; }
  .badge-critical { background: #B60205; }
  .badge-high { background: #D93F0B; }
  .badge-medium { background: #FBCA04; color: #1f2328; }
  .badge-low { background: #0E8A16; }
  .badge-non_compliant { background: #B60205; }
  .badge-partially_compliant { background: #FBCA04; color: #1f2328; }
  .badge-needs_review { background: #BFD4F2; color: #1f2328; }
  .badge-compliant { background: #0E8A16; }
  .traffic-light { display: inline-block; width: 24px; height: 24px; border-radius: 50%;
                   vertical-align: middle; margin-right: .5rem; }
  .light-green { background: #0E8A16; }
  .light-yellow { background: #FBCA04; }
  .light-red { background: #B60205; }
  .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
              gap: 1rem; margin: 1rem 0; }
  .kpi { background: white; border: 1px solid #d0d7de; border-radius: 6px; padding: 1rem; }
  .kpi-value { font-size: 1.8em; font-weight: 700; color: #0969da; }
  .kpi-label { font-size: 0.9em; color: #57606a; margin-top: .2rem; }
  .framework-card { background: white; border: 1px solid #d0d7de; border-radius: 6px;
                    padding: 1rem; margin-bottom: .8rem; }
  .disclaimer { background: #fff8c5; border-left: 4px solid #d4a72c; padding: .8rem 1rem;
                margin: 1rem 0; font-size: 0.92em; }
  footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #d0d7de;
           font-size: 0.85em; color: #57606a; }
  code { background: #f6f8fa; padding: 1px 4px; border-radius: 3px; }
</style>
</head>
<body>
<h1>{% block report_title %}Telemetrie Analyzer Report{% endblock %}</h1>
<p style="color:#57606a;">
  Erzeugt am <strong>{{ ctx.generated_at.strftime("%d.%m.%Y %H:%M UTC") }}</strong>
  {% if ctx.period_start and ctx.period_end %}
    · Analysezeitraum:
    <strong>{{ ctx.period_start.strftime("%d.%m.%Y") }}</strong>
    bis
    <strong>{{ ctx.period_end.strftime("%d.%m.%Y") }}</strong>
  {% endif %}
</p>
{% include "partials/_disclaimer.html.j2" %}
{% block content %}{% endblock %}
{% include "partials/_footer.html.j2" %}
</body>
</html>
