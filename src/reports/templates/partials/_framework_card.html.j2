<div class="ta-card">
  <div class="ta-card__head">
    <h3>{{ fv.framework_label }}</h3>
    <span class="ta-card__score {% if fv.score_percent >= 80 %}ta-card__score--ok{% elif fv.score_percent >= 50 %}ta-card__score--mid{% else %}ta-card__score--bad{% endif %}">
      {{ fv.score_percent }}% erfüllt
    </span>
  </div>
  <p class="ta-card__meta">
    {{ fv.triggered_controls }} von {{ fv.total_controls }} Controls betroffen ·
    <span class="ta-status ta-status-non-compliant">{{ fv.non_compliant }} non-compliant</span>
    <span class="ta-status ta-status-partial">{{ fv.partially_compliant }} partial</span>
    <span class="ta-status ta-status-needs-review">{{ fv.needs_review }} review</span>
  </p>
</div>
