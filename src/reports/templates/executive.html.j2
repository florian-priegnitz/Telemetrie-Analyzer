{% extends "base.html.j2" %}
{% block title %}Executive Report — Shadow AI Telemetrie{% endblock %}
{% block report_title %}Executive Summary — Shadow AI Telemetrie{% endblock %}
{% block content %}

<h2>Compliance-Status (Gesamtbild)</h2>
<p style="font-size:1.2em;">
  <span class="traffic-light light-{{ ctx.compliance_traffic_light }}"></span>
  Erfüllungsgrad über alle 6 Frameworks:
  <strong>{{ ctx.overall_compliance_percent }}%</strong>
</p>

<div class="kpi-grid">
  <div class="kpi"><div class="kpi-value">{{ ctx.unique_ai_services }}</div>
    <div class="kpi-label">Erkannte KI-Dienste</div></div>
  <div class="kpi"><div class="kpi-value">{{ ctx.unique_clients }}</div>
    <div class="kpi-label">Betroffene Clients (pseudonymisiert)</div></div>
  <div class="kpi"><div class="kpi-value">{{ ctx.upload_events_total }}</div>
    <div class="kpi-label">Verdächtige Uploads (&gt;500 KB)</div></div>
</div>

{{ ctx.charts.framework_scores_bar | safe }}

<h2>Top-Risiken</h2>
{% if ctx.top_findings %}
  <ol>
  {% for f in ctx.top_findings %}
    <li>
      <strong>{{ f.service }}</strong> ({{ f.provider }}) —
      <span class="badge badge-{{ f.risk_level }}">{{ f.risk_level }}</span>
      Score <strong>{{ f.risk_score }}</strong>:
      {{ f.queries_per_day }} Queries/Tag durch {{ f.client_pseudonym }}
      {% if f.has_document_upload %}, <strong>Dokument-Upload erkannt</strong>{% endif %}.
    </li>
  {% endfor %}
  </ol>
{% else %}
  <p><em>Keine kritischen Findings im Analysezeitraum.</em></p>
{% endif %}

<h2>Empfehlung</h2>
<p>
{% if ctx.compliance_traffic_light == "red" %}
  Der aktuelle Compliance-Erfüllungsgrad von <strong>{{ ctx.overall_compliance_percent }}%</strong>
  liegt im kritischen Bereich. Sofortmassnahmen erforderlich:
  Inventarisierung der erkannten {{ ctx.unique_ai_services }} KI-Dienste,
  Risikobewertung nach EU AI Act Art. 6, DSFA-Pflichtprüfung nach DSGVO Art. 35
  für die Top-Risiken. Eskalation an Geschäftsleitung und DSB binnen 5 Werktagen empfohlen.
{% elif ctx.compliance_traffic_light == "yellow" %}
  Mit <strong>{{ ctx.overall_compliance_percent }}%</strong> Compliance-Erfüllung
  besteht Handlungsbedarf, aber keine akute Krise. Empfehlung:
  Top-3 Findings binnen 30 Tagen formal bewerten, AI-Inventar nach ISO 42001 aufbauen,
  ICT-Drittanbieter nach DORA Art. 28 vertraglich regeln.
{% else %}
  Der Erfüllungsgrad von <strong>{{ ctx.overall_compliance_percent }}%</strong> ist solide.
  Empfehlung: bestehende Kontrollen aufrechterhalten, periodische Re-Analyse
  (vorgeschlagen quartalsweise) und Erweiterung der AI Endpoint Database.
{% endif %}
</p>

{% endblock %}
