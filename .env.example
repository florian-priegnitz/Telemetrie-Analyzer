# Telemetrie Analyzer — Konfiguration (Beispiel)
# Kopiere diese Datei nach .env und passe Werte an. .env ist in .gitignore.

# Claude API (optional — ohne Key läuft Skip-Mode)
ANTHROPIC_API_KEY=

# Pseudonymisierungs-Salts (HMAC-SHA256)
# Für reproduzierbare Pseudonyme über Sessions hinweg:
#   openssl rand -hex 32
# Leer = zufällig pro Prozess (sicherer, aber nicht session-übergreifend)
PSEUDONYM_SALT=
REPORT_SALT=

# Retention (DSGVO Art. 5 — Speicherbegrenzung)
RETENTION_DAYS=90
